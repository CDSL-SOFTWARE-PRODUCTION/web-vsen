APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# Currency: base = VND; rates = VND per 1 unit of foreign ISO 4217 (see config/currency.php).
CURRENCY_BASE=VND
CURRENCY_LEGACY_DEFAULT=VND
CURRENCY_RATE_USD_TO_VND=25000
CURRENCY_RATE_CNY_TO_VND=3500
CURRENCY_RATE_EUR_TO_VND=27000
CURRENCY_RATE_JPY_TO_VND=170
CURRENCY_RATE_KRW_TO_VND=18

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Business OS Ops gates: warn | hard (see config/ops.php and doc/guide.md — Layered flexibility & SSOT)
# OPS_GATE_CONFIRM_FULFILLMENT=warn
# OPS_GATE_INVOICE_PAYMENT_MILESTONE=warn
# OPS_GATE_AWARD_TENDER_DOCS=warn
# OPS_GATE_CONFIRM_CONTRACT_HD_KY=warn
# OPS_GATE_CONFIRM_CONTRACT_CREDIT_LIMIT=warn
# OPS_GATE_CONFIRM_CONTRACT_CERT=warn
# OPS_GATE_CONFIRM_CONTRACT_MARGIN=warn
# OPS_GATE_CLOSE_CONTRACT_DOCS=warn
# OPS_GATE_DELIVERY_GPS=warn
# OPS_PRICE_LIST_DEVIATION_WARN_PERCENT=10
# OPS_SUPPLY_PRICE_DEVIATION_HARD_PERCENT=10
# OPS_RESERVE_TTL_DAYS=30
# OPS_ROP_WARN_BELOW_QTY=10
# OPS_DELIVERY_GPS_MAX_METERS=500
#
# Demo tender (TBMT IB2600147617) — see database/fixtures/tender_snapshots/ib2600147617-milk-hue-2025.json
# OPS_SEED_DEMO_TENDER=false
# OPS_SEED_HUE_MILK_FULL=false
#
# Integrations (see config/integrations.php)
# MISA_INTEGRATION_ENABLED=false
# BANK_VA_WEBHOOK_ENABLED=false
