includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - routes
    level: 5
    treatPhpDocTypesAsCertain: false
    parallel:
        maximumNumberOfProcesses: 4
        jobSize: 40
